        "tags": ["وبلاگ"],
        "summary": "دریافت جزئیات پست",
        "description": "دریافت اطلاعات کامل یک پست وبلاگ شامل دسته‌بندی‌ها، نویسنده و پست‌های مشابه",
        "operationId": "getPostDetails",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "description": "شناسه یکتای پست",
            "schema": {
              "type": "string",
              "example": "post-slug"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "عملیات موفق",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": true},
                    "message": {"type": "string", "example": "پست با موفقیت دریافت شد"},
                    "data": {
                      "type": "object",
                      "properties": {
                        "post": {
                          "type": "object",
                          "properties": {
                            "id": {"type": "integer", "example": 1},
                            "title": {"type": "string", "example": "عنوان پست"},
                            "slug": {"type": "string", "example": "post-slug"},
                            "summary": {"type": "string", "example": "خلاصه پست"},
                            "body": {"type": "string", "example": "محتوای کامل پست"},
                            "image": {"type": "string", "example": "post.jpg"},
                            "image_alt": {"type": "string", "example": "alt text"},
                            "status": {"type": "integer", "example": 1},
                            "is_featured": {"type": "boolean", "example": true},
                            "commentable": {"type": "boolean", "example": true},
                            "tags": {"type": "array", "items": {"type": "string"}},
                            "views": {"type": "integer", "example": 100},
                            "likes": {"type": "integer", "example": 50},
                            "reading_time": {"type": "integer", "example": 5},
                            "reading_level": {"type": "string", "example": "beginner"},
                            "rating": {"type": "number", "example": 4.5},
                            "is_review": {"type": "boolean", "example": false},
                            "pros": {"type": "array", "items": {"type": "string"}},
                            "cons": {"type": "array", "items": {"type": "string"}},
                            "faq": {"type": "array", "items": {"type": "object"}},
                            "attachments": {"type": "array", "items": {"type": "string"}},
                            "meta_title": {"type": "string"},
                            "meta_description": {"type": "string"},
                            "meta_keywords": {"type": "string"},
                            "published_at": {"type": "string", "format": "date-time"},
                            "categories": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "id": {"type": "integer"},
                                  "title": {"type": "string"},
                                  "slug": {"type": "string"}
                                }
                              }
                            },
                            "author": {
                              "type": "object",
                              "properties": {
                                "id": {"type": "integer"},
                                "first_name": {"type": "string"},
                                "last_name": {"type": "string"}
                              }
                            }
                          }
                        },
                        "similar_posts": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {"type": "integer"},
                              "title": {"type": "string"},
                              "slug": {"type": "string"},
                              "summary": {"type": "string"},
                              "image": {"type": "string"},
                              "created_at": {"type": "string", "format": "date-time"}
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "پست یافت نشد",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": false},
                    "message": {"type": "string", "example": "پست یافت نشد"}
                  }
                }
              }
            }
          },
          "500": {
            "description": "خطای سرور",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": false},
                    "message": {"type": "string", "example": "خطا در دریافت اطلاعات پست"}
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "توکن JWT برای احراز هویت کاربران"
      },
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "کلید API برای دسترسی به اندپوینتها"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}

