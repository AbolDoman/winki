                    "success": {"type": "boolean", "example": true},
                    "message": {"type": "string", "example": "سفارش با موفقیت ثبت شد"},
                    "data": {
                      "type": "object",
                      "properties": {
                        "order_id": {"type": "integer", "example": 1},
                        "tracking_code": {"type": "string", "example": "ORD-17123456789"},
