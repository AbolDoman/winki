      "post": {
        "tags": ["سبد خرید"],
        "summary": "افزایش تعداد آیتم",
        "operationId": "incrementCartItem",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "requestBody": {
          "content": {
            "application/json": {
