                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": false},
                    "message": {"type": "string", "example": "لطفا کلمه کلیدی را وارد کنید"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/checkout": {
      "post": {
        "tags": ["سفارش"],
        "summary": "ثبت سفارش از سبد خرید",
        "description": "تبدیل سبد خرید به سفارش و فریز کردن موجودی",
        "operationId": "checkout",
