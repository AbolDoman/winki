        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cart_id", "address_id"],
                "properties": {
                  "cart_id": {"type": "integer", "example": 1, "description": "شناسه سبد خرید"},
                  "address_id": {"type": "integer", "example": 1, "description": "شناسه آدرس ارسال"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "سفارش با موفقیت ثبت شد",
