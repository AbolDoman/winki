            }
          }
        },
        "responses": {
          "200": {"description": "تعداد بروزرسانی شد"},
          "400": {"description": "موجودی کافی نیست"},
          "404": {"description": "آیتم یافت نشد"}
        }
      },
      "delete": {
        "tags": ["سبد خرید"],
        "summary": "حذف آیتم از سبد",
        "operationId": "removeCartItem",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {
          "200": {"description": "آیتم حذف شد"},
          "404": {"description": "آیتم یافت نشد"}
