    "/api/v1/products": {
      "get": {
        "tags": ["محصولات"],
        "summary": "دریافت لیست محصولات",
        "description": "دریافت لیست محصولات با فیلتر و جستجو",
        "operationId": "getProducts",
        "parameters": [
          {"name": "category_id", "in": "query", "required": false, "schema": {"type": "integer", "example": 1}},
          {"name": "brand_id", "in": "query", "required": false, "schema": {"type": "integer", "example": 1}},
          {"name": "search", "in": "query", "required": false, "schema": {"type": "string", "example": "لپتاپ"}},
          {"name": "sort", "in": "query", "required": false, "schema": {"type": "string", "enum": ["newest", "price_asc", "price_desc", "popular"]}},
          {"name": "per_page", "in": "query", "required": false, "schema": {"type": "integer", "example": 20}}
        ],
        "responses": {
          "200": {
            "description": "لیست محصولات",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": true},
                    "data": {
                      "type": "object",
                      "properties": {
                        "products": {
                          "type": "object",
                          "properties": {
                            "data": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "id": {"type": "integer", "example": 1},
                                  "title": {"type": "string", "example": "لپتاپ ایسوس"},
                                  "slug": {"type": "string", "example": "laptop-asus"},
                                  "price": {"type": "number", "example": 15000000},
                                  "image": {"type": "string", "example": "product.jpg"},
                                  "isFavorite": {"type": "boolean", "example": false}
                                }
                              }
                            },
                            "current_page": {"type": "integer", "example": 1},
                            "last_page": {"type": "integer", "example": 5},
                            "per_page": {"type": "integer", "example": 20},
                            "total": {"type": "integer", "example": 100}
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/product/{slug}": {
      "get": {
        "tags": ["محصولات"],
        "summary": "دریافت جزئیات محصول",
        "description": "دریافت اطلاعات کامل یک محصول شامل دسته‌بندی، برند، نویسنده، تنوع‌ها و محصولات مشابه",
        "operationId": "getProductDetails",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "description": "شناسه یکتای محصول",
            "schema": {
              "type": "string",
              "example": "product-slug"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "عملیات موفق",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": true},
                    "message": {"type": "string", "example": "محصول با موفقیت دریافت شد"},
                    "data": {
                      "type": "object",
                      "properties": {
                        "product": {
                          "type": "object",
                          "properties": {
                            "id": {"type": "integer", "example": 1},
                            "title": {"type": "string", "example": "عنوان محصول"},
                            "slug": {"type": "string", "example": "product-slug"},
                            "summary": {"type": "string", "example": "خلاصه محصول"},
                            "body": {"type": "string", "example": "توضیحات کامل محصول"},
                            "image": {"type": "string", "example": "product.jpg"},
                            "image_alt": {"type": "string", "example": "alt text"},
                            "price": {"type": "number", "example": 1000000},
                            "stock_status": {"type": "string", "example": "in_stock"},
                            "sku": {"type": "string", "example": "SKU-123"},
                            "status": {"type": "integer", "example": 1},
                            "is_featured": {"type": "boolean", "example": true},
                            "tags": {"type": "array", "items": {"type": "string"}},
                            "rating": {"type": "number", "example": 4.5},
                            "average_rating": {"type": "number", "example": 4.5},
                            "review_count": {"type": "integer", "example": 10},
                            "views": {"type": "integer", "example": 100},
                            "likes": {"type": "integer", "example": 50},
                            "wishlist_count": {"type": "integer", "example": 20},
                            "purchase_count": {"type": "integer", "example": 30},
                            "warranty": {"type": "string", "example": "1 year"},
                            "delivery_time": {"type": "string", "example": "2-3 days"},
                            "return_policy": {"type": "string", "example": "7 days"},
                            "pros": {"type": "array", "items": {"type": "string"}},
                            "cons": {"type": "array", "items": {"type": "string"}},
                            "faq": {"type": "array", "items": {"type": "object"}},
                            "attachments": {"type": "array", "items": {"type": "string"}},
                            "custom_badges": {"type": "array", "items": {"type": "string"}},
                            "meta_title": {"type": "string"},
                            "meta_description": {"type": "string"},
                            "meta_keywords": {"type": "string"},
                            "category": {
                              "type": "object",
                              "properties": {
                                "id": {"type": "integer"},
                                "title": {"type": "string"},
                                "slug": {"type": "string"}
                              }
                            },
                            "brand": {
                              "type": "object",
                              "properties": {
                                "id": {"type": "integer"},
                                "name": {"type": "string"},
                                "slug": {"type": "string"}
                              }
                            },
                            "author": {
                              "type": "object",
                              "properties": {
                                "id": {"type": "integer"},
                                "first_name": {"type": "string"},
                                "last_name": {"type": "string"}
                              }
                            },
                            "variants": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "id": {"type": "integer"},
                                  "name": {"type": "string"},
                                  "price": {"type": "number"},
                                  "stock": {"type": "integer"}
                                }
                              }
                            }
                          }
                        },
                        "similar_products": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {"type": "integer"},
                              "title": {"type": "string"},
                              "slug": {"type": "string"},
                              "price": {"type": "number"},
                              "image": {"type": "string"},
                              "average_rating": {"type": "number"}
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "محصول یافت نشد",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": false},
                    "message": {"type": "string", "example": "محصول یافت نشد"}
                  }
                }
              }
            }
          },
          "500": {
            "description": "خطای سرور",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": false},
                    "message": {"type": "string", "example": "خطا در دریافت اطلاعات محصول"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/cart/add": {
      "post": {
        "tags": ["سبد خرید"],
        "summary": "افزودن محصول به سبد خرید",
        "description": "افزودن محصول به سبد خرید کاربر با امکان انتخاب متغیر محصول",
        "operationId": "addToCart",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["product_id", "quantity"],
                "properties": {
                  "product_id": {"type": "integer", "example": 1},
                  "product_variant_id": {"type": "integer", "nullable": true, "example": 1},
                  "quantity": {"type": "integer", "example": 1, "minimum": 1}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "محصول با موفقیت به سبد خرید اضافه شد",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": true},
                    "message": {"type": "string", "example": "محصول به سبد خرید اضافه شد"},
                    "data": {
                      "type": "object",
                      "properties": {
                        "cart": {
                          "type": "object",
                          "properties": {
                            "id": {"type": "integer", "example": 1},
                            "total_items": {"type": "integer", "example": 3},
                            "total_amount": {"type": "number", "example": 2500000}
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {"description": "خطای اعتبارسنجی یا موجودی کافی نیست"},
          "401": {"description": "کاربر احراز هویت نشده"},
          "404": {"description": "محصول یافت نشد"}
        }
      }
    },
    "/api/v1/cart": {
      "get": {
        "tags": ["سبد خرید"],
        "summary": "دریافت سبد خرید",
