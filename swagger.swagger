{
  "openapi": "3.0.0",
  "info": {
    "title": "Shop Backend API",
    "version": "1.0.0",
    "description": "API Documentation for Shop Backend"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local Development Server"
    }
    ,
    {
      "url" :"https://api.winki.ir",
      "description" : "Production Server"
    }
  ],
  "paths": {

    "/api/v1/customer/profile": {
      "get": {
        "tags": ["پروفایل مشتری"],
        "summary": "دریافت خلاصه پروفایل",
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {"description": "موفق"},
          "401": {"description": "احراز هویت نشده"}
        }
      },
      "put": {
        "tags": ["پروفایل مشتری"],
        "summary": "ویرایش پروفایل",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "first_name": {"type": "string", "example": "علی"},
                  "last_name": {"type": "string", "example": "احمدی"},
                  "email": {"type": "string", "example": "ali@example.com"},
                  "national_code": {"type": "string", "example": "1234567890"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "موفق"}
        }
      }
    },
    "/api/v1/customer/profile/update": {
      "put": {
        "tags": ["پروفایل مشتری"],
        "summary": "بهروزرسانی پروفایل",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "first_name": {"type": "string", "example": "علی"},
                  "last_name": {"type": "string", "example": "احمدی"},
                  "email": {"type": "string", "example": "ali@example.com"},
                  "national_code": {"type": "string", "example": "1234567890"},
                  "card_number": {"type": "string", "example": "6037991234567890"},
                  "iban": {"type": "string", "example": "IR123456789012345678901234"},
                  "password": {"type": "string", "example": "Aa123456@"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "موفق"}
        }
      }
    },
    "/api/v1/customer/profile/info": {
      "get": {
        "tags": ["پروفایل مشتری"],
        "summary": "اطلاعات کامل پروفایل",
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {"description": "موفق"}
        }
      }
    },
    "/api/v1/customer/profile/orders": {
      "get": {
        "tags": ["پروفایل مشتری"],
        "summary": "لیست سفارشات",
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {"description": "موفق"}
        }
      }
    },
    "/api/v1/customer/profile/orders/{id}": {
      "get": {
        "tags": ["پروفایل مشتری"],
        "summary": "جزئیات سفارش",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {
          "200": {"description": "موفق"}
        }
      }
    },
    "/api/v1/customer/addresses": {
      "get": {
        "tags": ["آدرس مشتری"],
        "summary": "لیست آدرسها",
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {"description": "موفق"}
        }
      },
      "post": {
        "tags": ["آدرس مشتری"],
        "summary": "ایجاد آدرس",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "province", "city", "address", "postal_code", "receiver_name", "receiver_mobile"],
                "properties": {
                  "title": {"type": "string", "example": "منزل"},
                  "province": {"type": "string", "example": "تهران"},
                  "city": {"type": "string", "example": "تهران"},
                  "address": {"type": "string", "example": "خیابان ولیعصر"},
                  "postal_code": {"type": "string", "example": "1234567890"},
                  "receiver_name": {"type": "string", "example": "علی احمدی"},
                  "receiver_mobile": {"type": "string", "example": "09123456789"},
                  "is_default": {"type": "boolean", "example": true}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "ایجاد شد"}
        }
      }
    },
    "/api/v1/customer/addresses/{id}": {
      "get": {
        "tags": ["آدرس مشتری"],
        "summary": "جزئیات آدرس",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {
          "200": {"description": "موفق"}
        }
      },
      "put": {
        "tags": ["آدرس مشتری"],
        "summary": "ویرایش آدرس",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {"type": "string"},
                  "province": {"type": "string"},
                  "city": {"type": "string"},
                  "address": {"type": "string"},
                  "postal_code": {"type": "string"},
                  "receiver_name": {"type": "string"},
                  "receiver_mobile": {"type": "string"},
                  "is_default": {"type": "boolean"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "موفق"}
        }
      },
      "delete": {
        "tags": ["آدرس مشتری"],
        "summary": "حذف آدرس",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {
          "200": {"description": "حذف شد"}
        }
      }
    },
    "/api/v1/customer/favorites": {
      "get": {
        "tags": ["علاقه‌مندی‌ها"],
        "summary": "لیست علاقه‌مندی‌ها",
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {"description": "موفق"}
        }
      }
    },
    "/api/v1/customer/favorites/{productId}": {
      "post": {
        "tags": ["علاقه‌مندی‌ها"],
        "summary": "افزودن به علاقه‌مندی‌ها",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "productId", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {
          "201": {"description": "اضافه شد"}
        }
      },
      "delete": {
        "tags": ["علاقه‌مندی‌ها"],
        "summary": "حذف از علاقه‌مندی‌ها",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "productId", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {
          "200": {"description": "حذف شد"}
        }
      }
    },
    "/api/v1/customer/reviews": {
      "get": {
        "tags": ["نظرات"],
        "summary": "لیست نظرات",
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {"description": "موفق"}
        }
      },
      "post": {
        "tags": ["نظرات"],
        "summary": "ثبت نظر",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["product_id", "rating"],
                "properties": {
                  "product_id": {"type": "integer", "example": 1},
                  "rating": {"type": "integer", "example": 5, "minimum": 1, "maximum": 5},
                  "comment": {"type": "string", "example": "محصول عالی"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "ثبت شد"}
        }
      }
    },
    "/api/v1/customer/reviews/{id}": {
      "put": {
        "tags": ["نظرات"],
        "summary": "ویرایش نظر",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "rating": {"type": "integer", "minimum": 1, "maximum": 5},
                  "comment": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "موفق"}
        }
      },
      "delete": {
        "tags": ["نظرات"],
        "summary": "حذف نظر",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {
          "200": {"description": "حذف شد"}
        }
      }
    }
,
    "/api/v1/auth/login": {
      "post": {
        "tags": ["احراز هویت"],
        "summary": "ورود با ایمیل یا موبایل",
        "description": "ورود کاربر با استفاده از ایمیل یا شماره موبایل و رمز عبور. سیستم به طور خودکار تشخیص میدهد ورودی ایمیل است یا موبایل",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["login", "password"],
                "properties": {
                  "login": {
                    "type": "string",
                    "example": "09123456789",
                    "description": "ایمیل یا شماره موبایل (فارسی یا انگلیسی)"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "minLength": 6,
                    "example": "password123",
                    "description": "رمز عبور (حداقل 6 کاراکتر)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ورود موفق",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": true},
                    "message": {"type": "string", "example": "Login successful"},
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": {"type": "string", "example": "1|sanctum_token_here"},
                        "user": {
                          "type": "object",
                          "properties": {
                            "id": {"type": "integer", "example": 1},
                            "first_name": {"type": "string", "example": "علی"},
                            "last_name": {"type": "string", "example": "محمدی"},
                            "mobile": {"type": "string", "example": "09123456789"},
                            "email": {"type": "string", "example": "user@example.com"},
                            "status": {"type": "string", "example": "active"},
                            "is_active": {"type": "boolean", "example": true}
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "خطای اعتبارسنجی",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": false},
                    "message": {"type": "string", "example": "Validation failed"},
                    "data": {"type": "null"}
                  }
                }
              }
            }
          },
          "401": {
            "description": "اطلاعات ورود نامعتبر",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": false},
                    "message": {"type": "string", "example": "Invalid credentials"},
                    "data": {"type": "null"}
                  }
                }
              }
            }
          },
          "403": {
            "description": "حساب کاربری غیرفعال",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": false},
                    "message": {"type": "string", "example": "Account is inactive"},
                    "data": {"type": "null"}
                  }
                }
              }
            }
          },
          "500": {
            "description": "خطای سرور",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": false},
                    "message": {"type": "string", "example": "Login failed"},
                    "data": {"type": "null"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/otp/send": {
      "post": {
        "tags": ["احراز هویت"],
        "summary": "ارسال کد OTP",
        "description": "ارسال کد یکبار مصرف به شماره موبایل کاربر. اگر کاربر وجود نداشته باشد، ایجاد میشود. محدودیت: یک درخواست هر 2 دقیقه",
        "operationId": "sendOtp",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["mobile"],
                "properties": {
                  "mobile": {
                    "type": "string",
                    "pattern": "^09[0-9]{9}$",
                    "example": "09123456789",
                    "description": "شماره موبایل (فارسی یا انگلیسی)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "کد OTP با موفقیت ارسال شد",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": true},
                    "message": {"type": "string", "example": "OTP sent successfully"},
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": {"type": "string", "example": "akUG2cr1F1Ik0y5lFRzrEGvtcE4ZUjiKZq6LEFrnfPavFHP1iYkUlIWia7ehvrfq"},
                        "code": {"type": "string", "example": "224382", "description": "فقط در محیط local"}
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "خطای اعتبارسنجی",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": false},
                    "message": {"type": "string", "example": "Validation failed"},
                    "data": {"type": "null"}
                  }
                }
              }
            }
          },
          "429": {
            "description": "درخواست زودهنگام - باید 2 دقیقه صبر کنید",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": false},
                    "message": {"type": "string", "example": "Please wait 120 seconds before requesting a new OTP"},
                    "data": {"type": "null"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/otp/verify": {
      "post": {
        "tags": ["احراز هویت"],
        "summary": "تایید کد OTP",
        "description": "تایید کد یکبار مصرف و دریافت توکن احراز هویت. محدودیت: 3 تلاش اشتباه",
        "operationId": "verifyOtp",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token", "code"],
                "properties": {
                  "token": {
                    "type": "string",
                    "example": "akUG2cr1F1Ik0y5lFRzrEGvtcE4ZUjiKZq6LEFrnfPavFHP1iYkUlIWia7ehvrfq",
                    "description": "توکن دریافتی از مرحله ارسال OTP"
                  },
                  "code": {
                    "type": "string",
                    "pattern": "^[0-9]{6}$",
                    "example": "224382",
                    "description": "کد 6 رقمی ارسال شده به موبایل"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ورود موفق",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": true},
                    "message": {"type": "string", "example": "Login successful"},
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": {"type": "string", "example": "1|1UqXcvTYMSpm2lWz7AGIKdixWsxfB70R6JxvsaKl6a319472"},
                        "user": {
                          "type": "object",
                          "properties": {
                            "id": {"type": "integer", "example": 2},
                            "first_name": {"type": "string", "example": "مشتری"},
                            "last_name": {"type": "string", "example": "09198461431"},
                            "mobile": {"type": "string", "example": "09198461431"},
                            "email": {"type": "string", "nullable": true, "example": null},
                            "status": {"type": "string", "example": "pending"},
                            "is_active": {"type": "boolean", "example": true}
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "کد نامعتبر یا منقضی شده",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": false},
                    "message": {"type": "string", "example": "Invalid or expired OTP"},
                    "data": {"type": "null"}
                  }
                }
              }
            }
          },
          "429": {
            "description": "تلاش بیش از حد - 3 بار کد اشتباه",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": false},
                    "message": {"type": "string", "example": "Too many failed attempts. Please wait 120 seconds or request a new OTP"},
                    "data": {"type": "null"}
                  }
                }
              }
            }
          }
        }
      }
    },

    "/api/v1/home/categories": {
      "get": {
        "tags": ["صفحه اصلی"],
        "summary": "دریافت لیست دسته بندی ها",
        "description": "دریافت لیست دسته بندی ها",
        "operationId": "getCategories",
        "responses": {
          "200": {
            "description": "لیست دسته بندی ها",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": true},
                    "data": {
                      "type": "object",
                      "properties": {
                        "categories": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {"type": "integer", "example": 1},
                              "title": {"type": "string", "example": "تکنولوژی"},
                              "slug": {"type": "string", "example": "technology"},
                              "image": {"type": "string", "example": "category.jpg"},
                              "icon": {"type": "string", "example": "icon.svg"}
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/home/layout": {
      "get": {
        "tags": ["صفحه اصلی"],
        "summary": "دریافت لایت اصلی",
        "description": "دریافت لایت اصلی",
        "operationId": "getLayout",
        "responses": {
          "200": {
            "description": "لایت اصلی",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": true},
                    "data": {
                      "type": "object",
                      "properties": {
                        "categories": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {"type": "integer", "example": 1},
                              "title": {"type": "string", "example": "تکنولوژی"},
                              "slug": {"type": "string", "example": "technology"},
                              "image": {"type": "string", "example": "category.jpg"},
                              "icon": {"type": "string", "example": "icon.svg"}
                            }
                          }
                        },
                        "menus": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {"type": "integer", "example": 1},
                              "title": {"type": "string", "example": "منوی اصلی"},
                              "location": {"type": "string", "example": "header"},
                              "items": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "id": {"type": "integer", "example": 1},
                                    "menu_id": {"type": "integer", "example": 1},
                                    "title": {"type": "string", "example": "خانه"},
                                    "url": {"type": "string", "example": "/"},
                                    "target": {"type": "string", "example": "_self"},
                                    "icon": {"type": "string", "example": "home"},
                                    "order": {"type": "integer", "example": 1}
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/home/menus": {
      "get": {
        "tags": ["صفحه اصلی"],
        "summary": "دریافت لیست منوها",
        "description": "دریافت لیست منوها",
        "operationId": "getMenus",
        "responses": {
          "200": {
            "description": "لیست منوها",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean", "example": true},
                    "data": {
                      "type": "object",
                      "properties": {
                        "menus": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {"type": "integer", "example": 1},
                              "title": {"type": "string", "example": "منوی اصلی"},
                              "location": {"type": "string", "example": "header"},
                              "items": {
                                "type": "array",
                                "items": {
