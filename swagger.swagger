                              "id": {"type": "integer", "example": 1},
                              "title": {"type": "string", "example": "لپتاپ ایسوس"},
                              "slug": {"type": "string", "example": "laptop-asus"},
                              "image": {"type": "string", "example": "/images/product.jpg"}
                            }
                          }
                        },
                        "posts": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {"type": "integer", "example": 1},
                              "title": {"type": "string", "example": "راهنمای خرید لپتاپ"},
                              "slug": {"type": "string", "example": "laptop-guide"},
                              "image": {"type": "string", "example": "/images/post.jpg"}
                            }
                          }
                        },
                        "brands": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {"type": "integer", "example": 1},
                              "title": {"type": "string", "example": "ایسوس"},
                              "slug": {"type": "string", "example": "asus"}
                            }
                          }
                        },
                        "categories": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {"type": "integer", "example": 1},
                              "title": {"type": "string", "example": "لپتاپ"},
                              "slug": {"type": "string", "example": "laptop"},
                              "image": {"type": "string", "example": "/images/category.jpg"}
